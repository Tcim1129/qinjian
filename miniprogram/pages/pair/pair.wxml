<!--配对管理页-->
<view class="container">
  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:else>
    <!-- 未配对状态 (参考图 1 风格) -->
    <view wx:if="{{!isPaired}}" class="not-paired-creamy animate-fade-in">
      <view class="creamy-header">
        <view class="creamy-title">还差一步：绑定另一半</view>
      </view>

      <!-- 我的邀请码区域 -->
      <view class="invite-section card-creamy">
        <view class="invite-info">
          <text class="invite-label">我的真爱码：</text>
          <text class="invite-value">{{pairInfo.invite_code || '------'}}</text>
          <view class="copy-tag" bindtap="copyInviteCode">复制</view>
        </view>
        
        <view class="bind-input-group">
          <input 
            class="bind-input" 
            placeholder="输入对方提供的真爱码" 
            placeholder-style="color: #B2BEC3;"
            value="{{inviteCode}}"
            bindinput="onInviteCodeInput"
          />
          <view class="bind-btn {{inviteCode.length === 6 ? 'active' : ''}}" bindtap="joinPair">绑定</view>
        </view>

        <view class="invite-btn-wrap">
          <button open-type="share" class="invite-link-btn">
            <text class="icon-phone">📱</text> 邀请对方下载
          </button>
        </view>
      </view>

      <view class="feature-tip">绑定另一半即可体验以下情侣专属私密功能</view>

      <!-- 功能磁贴网格 (20个) -->
      <view class="feature-grid-creamy">
        <view class="feature-item-creamy" wx:for="{{featureIcons}}" wx:key="name">
          <view class="feature-icon-wrapper" style="background: {{item.bg}}">
            <text class="feature-emoji">{{item.icon}}</text>
          </view>
          <text class="feature-name-creamy">{{item.name}}</text>
        </view>
      </view>

      <!-- 底部滚动通知 -->
      <view class="notice-bar-creamy">
        <text class="notice-icon">📢</text>
        <swiper class="notice-swiper" vertical autoplay circular interval="3000">
          <swiper-item wx:for="{{notices}}" wx:key="*this">
            <text class="notice-text">{{item}}</text>
          </swiper-item>
        </swiper>
      </view>
    </view>

    <!-- 已配对状态 -->
    <view wx:else class="paired">
      <view class="pair-header gradient-card">
        <view class="paired-status">已配对 · {{pairInfo.type === 'spouse' ? '夫妻' : pairInfo.type === 'bestfriend' ? '挚友' : '情侣'}}</view>
        <view class="partner-info">
          <view class="partner-avatar">{{partnerInitial}}</view>
          <view class="partner-name">{{partnerDisplay}}</view>
          <view class="partner-account" wx:if="{{pairInfo.partner_email || pairInfo.partner_phone}}">
            {{pairInfo.partner_phone || pairInfo.partner_email}}
          </view>
        </view>
        <view class="pair-date">配对时间：{{pairInfo.created_at || '--'}}</view>
        <view class="pair-actions" wx:if="{{pairInfo.partner_id}}">
          <button class="btn btn-small btn-ghost" bindtap="showSetNicknameModal">设置备注名</button>
        </view>
      </view>

      <!-- 关系统计 -->
      <view class="stats-grid mt-lg">
        <view class="stat-item card">
          <view class="stat-value">{{pairInfo.checkin_days || 0}}</view>
          <view class="stat-label">共同打卡天数</view>
        </view>
        <view class="stat-item card">
          <view class="stat-value">{{pairInfo.relationship_days || 0}}</view>
          <view class="stat-label">在一起天数</view>
        </view>
      </view>

      <!-- 邀请码 -->
      <view wx:if="{{pairInfo.invite_code}}" class="card mt-md">
        <view class="card-title">我的配对码</view>
        <view class="invite-code-wrap flex-between">
          <text class="invite-code">{{pairInfo.invite_code}}</text>
          <button class="btn btn-small btn-ghost" bindtap="copyInviteCode">复制</button>
        </view>
      </view>

      <!-- 我的配对列表 -->
      <view wx:if="{{pairList.length > 0}}" class="card mt-md">
        <view class="card-title">我的配对</view>
        <view class="pair-list">
          <block wx:for="{{pairList}}" wx:key="id">
            <view class="pair-item">
              <view class="pair-item-info">
                <view class="pair-item-name">
                  {{item.partner_nickname || item.partner_name || item.partnerNickname || '伴侣'}}
                </view>
                <view class="pair-item-meta">
                  {{item.type || 'couple'}} · {{item.status || 'active'}}
                </view>
              </view>
              <button
                class="btn btn-small btn-ghost"
                bindtap="setCurrentPair"
                data-pair="{{item}}"
              >
                设为当前
              </button>
            </view>
          </block>
        </view>
      </view>

      <!-- 加入新配对（多配对） -->
      <view class="card mt-lg">
        <view class="card-title">加入新的配对</view>
        <view class="card-desc">输入伴侣分享的配对码</view>
        <view class="input-wrap mt-sm">
          <input
            type="text"
            placeholder="请输入配对码"
            value="{{inviteCode}}"
            bindinput="onInviteCodeInput"
          />
        </view>
        <button
          class="btn btn-secondary btn-block mt-md"
          bindtap="joinPair"
          disabled="{{joining}}"
        >
          {{joining ? '加入中...' : '加入配对'}}
        </button>
      </view>

      <!-- 解除配对 -->
      <view class="card mt-lg danger-card">
        <view class="card-title text-danger">解除配对</view>
        <view class="card-desc">解除后所有配对数据将被清除，此操作不可撤销</view>
        <button class="btn btn-outline btn-block mt-md" style="border-color: var(--color-danger); color: var(--color-danger);" bindtap="handleUnbind">
          解除配对
        </button>
      </view>
    </view>
  </block>

  <!-- 设置备注名弹窗 -->
  <view class="modal" wx:if="{{showNicknameModal}}">
    <view class="modal-mask" bindtap="hideNicknameModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <view class="modal-title">设置伴侣备注名</view>
        <text class="modal-close" bindtap="hideNicknameModal">×</text>
      </view>
      <view class="modal-body">
        <view class="input-wrap mb-md">
          <input
            placeholder="给伴侣起个备注名"
            value="{{customNicknameInput}}"
            bindinput="onNicknameInput"
            maxlength="20"
          />
        </view>
        <view class="text-small text-muted">设置备注名后，首页和配对页将显示此名称</view>
      </view>
      <view class="modal-footer">
        <button class="btn btn-secondary" bindtap="hideNicknameModal">取消</button>
        <button class="btn btn-primary" bindtap="saveCustomNickname">保存</button>
      </view>
    </view>
  </view>
</view>
