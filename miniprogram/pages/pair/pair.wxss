/* 配对管理页样式 */
.container {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 未配对状态 */
.not-paired {
  padding-top: 60rpx;
}

.pair-header {
  text-align: center;
  padding: 48rpx 32rpx;
}

.pair-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.pair-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.pair-subtitle {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.card-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* 已配对状态 */
.paired .pair-header {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  border-radius: var(--radius-lg);
  color: #ffffff;
  margin-bottom: 0;
}

.paired-status {
  display: inline-block;
  padding: 8rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-bottom: 20rpx;
}

.partner-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 24rpx 0;
}

.partner-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.partner-name {
  font-size: 32rpx;
  font-weight: 600;
}

.pair-date {
  font-size: 22rpx;
  opacity: 0.8;
}

/* 统计网格 */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1.2;
}

.stat-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

/* 邀请码 */
.invite-code-wrap {
  margin-top: 16rpx;
  padding: 20rpx 24rpx;
  background: var(--color-bg);
  border-radius: var(--radius-md);
}

.invite-code {
  font-size: 32rpx;
  font-weight: 600;
  font-family: 'Courier New', monospace;
  color: var(--color-primary);
  letter-spacing: 4rpx;
}

.pair-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 12rpx;
}

.pair-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 12rpx;
  border-radius: 16rpx;
  background: #fff5f1;
}

.pair-item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d2a32;
}

.pair-item-meta {
  font-size: 22rpx;
  color: #8f8a9c;
  margin-top: 4rpx;
}

/* 危险卡片 */
.danger-card {
  border: 2rpx solid rgba(255, 107, 107, 0.3);
}

.text-danger {
  color: var(--color-danger);
}

/* 加载状态 */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.loading-text {
  font-size: 28rpx;
  color: var(--color-text-muted);
}
