/* 配对管理页样式 */
.container {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 未配对状态 */
.not-paired {
  padding-top: 60rpx;
}

.pair-header {
  text-align: center;
  padding: 48rpx 32rpx;
}

.pair-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.pair-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.pair-subtitle {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.card-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* 已配对状态 */
.paired .pair-header {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  border-radius: var(--radius-lg);
  color: #ffffff;
  margin-bottom: 0;
}

.paired-status {
  display: inline-block;
  padding: 8rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-bottom: 20rpx;
}

.partner-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 24rpx 0;
}

.partner-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.partner-name {
  font-size: 32rpx;
  font-weight: 600;
}

.pair-date {
  font-size: 22rpx;
  opacity: 0.8;
}

/* 统计网格 */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1.2;
}

.stat-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

/* 邀请码 */
.invite-code-wrap {
  margin-top: 16rpx;
  padding: 20rpx 24rpx;
  background: var(--color-bg);
  border-radius: var(--radius-md);
}

.invite-code {
  font-size: 32rpx;
  font-weight: 600;
  font-family: 'Courier New', monospace;
  color: var(--color-primary);
  letter-spacing: 4rpx;
}

.pair-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 12rpx;
}

.pair-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 12rpx;
  border-radius: 16rpx;
  background: #fff5f1;
}

.pair-item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d2a32;
}

.pair-item-meta {
  font-size: 22rpx;
  color: #8f8a9c;
  margin-top: 4rpx;
}

/* 危险卡片 */
.danger-card {
  border: 2rpx solid rgba(255, 107, 107, 0.3);
}

.text-danger {
  color: var(--color-danger);
}

/* 加载状态 */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.loading-text {
  font-size: 28rpx;
  color: var(--color-text-muted);
}

/* 伴侣账号信息 */
.partner-account {
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 8rpx;
}

.pair-actions {
  margin-top: 16rpx;
}

/* 弹窗样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 80%;
  max-width: 600rpx;
  background: #ffffff;
  border-radius: var(--radius-lg);
  padding: 32rpx;
  z-index: 1001;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
}

.modal-close {
  font-size: 40rpx;
  color: var(--color-text-secondary);
  padding: 0 8rpx;
}

.modal-body {
  margin-bottom: 32rpx;
}

.modal-footer {
  display: flex;
  gap: 24rpx;
}

.modal-footer .btn {
  flex: 1;
}

.text-muted {
  color: var(--color-text-secondary);
}
/* ===== 奶油奶油风 (Creamy) 专属扩展 ===== */
.not-paired-creamy {
  padding: 40rpx 32rpx;
  background-color: var(--color-cream-bg);
  min-height: 100vh;
}

.creamy-header {
  text-align: center;
  margin-bottom: 48rpx;
  padding: 80rpx 40rpx 100rpx;
  background: linear-gradient(135deg, #5d4037, #8d6e63);
  border-radius: 0 0 60rpx 60rpx;
}

.creamy-title {
  font-size: 38rpx;
  font-weight: 800;
  color: var(--color-cream-text);
  letter-spacing: 2rpx;
}

.invite-section {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  background: #ffffff;
}

.invite-info {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.invite-label {
  font-size: 28rpx;
  color: var(--color-cream-text);
}

.invite-value {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-cream-text);
  font-family: 'PingFang SC', monospace;
}

.copy-tag {
  font-size: 22rpx;
  color: #ff8e9b;
  background: #fff0f3;
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
  border: 1rpx solid #ffd1d9;
}

.bind-input-group {
  display: flex;
  background: #f5f5f5;
  border-radius: 50rpx;
  padding: 8rpx 8rpx 8rpx 32rpx;
  align-items: center;
}

.bind-input {
  flex: 1;
  font-size: 26rpx;
  color: var(--color-cream-text);
}

.bind-btn {
  background: #e0e0e0;
  color: #ffffff;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 600;
  transition: all 0.2s;
}

.bind-btn.active {
  background: #2d2a32;
  color: #ffffff;
}

.invite-btn-wrap {
  display: flex;
  justify-content: center;
}

.invite-link-btn {
  background: #ffffff;
  border: 2rpx solid #7ed321;
  color: #7ed321;
  font-size: 28rpx;
  font-weight: 600;
  height: 80rpx;
  display: flex;
  align-items: center;
  border-radius: 40rpx;
  padding: 0 60rpx;
  box-shadow: 0 4rpx 12rpx rgba(126, 211, 33, 0.1);
}

.invite-link-btn::after { border: none; }

.icon-phone { margin-right: 12rpx; }

.feature-tip {
  text-align: center;
  font-size: 24rpx;
  color: #b2b2b2;
  margin: 48rpx 0 32rpx;
}

/* 5列网格 */
.feature-grid-creamy {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 24rpx 12rpx;
  margin-bottom: 60rpx;
}

.feature-item-creamy {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.feature-icon-wrapper {
  width: 88rpx;
  height: 88rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 10rpx rgba(93, 64, 55, 0.05);
  background: #fff9f0;
}

.feature-emoji {
  font-size: 40rpx;
}

.feature-name-creamy {
  font-size: 20rpx;
  color: var(--color-cream-text);
  white-space: nowrap;
}

/* 底部公告栏 */
.notice-bar-creamy {
  background: #fff9e6;
  border-radius: 12rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  margin-top: 20rpx;
}

.notice-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
}

.notice-swiper {
  flex: 1;
  height: 100%;
}

.notice-text {
  font-size: 24rpx;
  color: #e67e22;
  line-height: 72rpx;
}
