/* 首页特有样式 */

.home-header-creamy {
  margin: calc(-1 * var(--spacing-lg));
  margin-bottom: 48rpx;
  padding: 80rpx 40rpx 120rpx;
  background: linear-gradient(135deg, #fff3e8 0%, #fbf2ea 48%, #eef8fa 100%);
  border-radius: 0 0 80rpx 80rpx;
  position: relative;
}

.home-header-main {
  margin-top: 30rpx;
}

.home-greeting {
  font-size: 44rpx;
  font-weight: 800;
  color: #3e2723;
  letter-spacing: 2rpx;
}

.home-pair-status-creamy {
  font-size: 24rpx;
  color: #8d6e63;
  margin-top: 12rpx;
}

.home-mood-capsule {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(255, 255, 255, 0.86);
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  border: 1rpx solid rgba(212, 163, 115, 0.14);
  box-shadow: 0 12rpx 28rpx rgba(93, 64, 55, 0.08);
}

.mood-emoji-sm { font-size: 32rpx; }
.mood-label-sm { font-size: 20rpx; color: #5d4037; font-weight: 700; }

.home-hero-card {
  margin-top: 28rpx;
  padding: 32rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(255, 249, 242, 0.9));
  border: 1rpx solid rgba(212, 163, 115, 0.14);
  box-shadow: 0 18rpx 40rpx rgba(93, 64, 55, 0.08);
}

.home-hero-card__eyebrow {
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: #a1887f;
  text-transform: uppercase;
}

.home-hero-card__title {
  margin-top: 14rpx;
  font-size: 36rpx;
  line-height: 1.3;
  font-weight: 800;
  color: #3e2723;
}

.home-hero-card__copy {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #6d4c41;
}

.home-pair-status {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: var(--spacing-xs);
}

.home-mood-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: var(--radius-lg);
  padding: var(--spacing-sm) var(--spacing-md);
}

.mood-emoji {
  font-size: 48rpx;
}

.mood-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 4rpx;
}

/* 危机横幅 */
.crisis-banner {
  background: rgba(255, 107, 107, 0.08);
  border: 2rpx solid rgba(255, 107, 107, 0.2);
}

.crisis-icon {
  font-size: 40rpx;
}

/* 打卡天数 (奶油风格大卡片) */
.streak-card-creamy {
  margin-top: -60rpx;
  position: relative;
  z-index: 10;
  text-align: center;
  padding: 60rpx 40rpx;
}

.streak-number-creamy {
  font-size: 112rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #5d4037, #d4a373);
  -webkit-background-clip: text;
  color: transparent;
  line-height: 1;
  letter-spacing: -2rpx;
}

.streak-label-creamy {
  font-size: 24rpx;
  color: #8f8ba8;
  margin-top: 16rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* 标题样式 */
.section-title-creamy {
  font-size: 32rpx;
  font-weight: 800;
  color: #2d2a32;
}

/* 快捷操作卡片 */
.action-card-creamy {
  text-align: center;
  padding: 40rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.action-icon-creamy {
  font-size: 64rpx;
}

.action-text-creamy {
  font-size: 26rpx;
  font-weight: 700;
  color: #333;
}

.action-status-creamy {
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.action-status-creamy.done { background: #E8F5E9; color: #2E7D32; font-weight: 700; }
.action-status-creamy.pending { background: #FFF3E0; color: #E67E22; font-weight: 700; }

.action-sub-creamy {
  font-size: 20rpx;
  color: #999;
}
