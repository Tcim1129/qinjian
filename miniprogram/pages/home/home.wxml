<!--
  首页 - 亲健
  顶部渐变区域 + 快捷操作卡片 + 打卡天数 + 危机横幅
-->
<view class="container container-safe">

  <!-- 顶部渐变头部：问候、配对状态 -->
  <view class="home-header-creamy">
    <view class="brand-ribbon">
      <image class="brand-ribbon__logo" src="/images/brand-logo.jpg" mode="aspectFit"></image>
      <view class="brand-ribbon__copy">
        <view class="brand-ribbon__eyebrow">QINJIAN MINI</view>
        <view class="brand-ribbon__title">把关系慢慢照顾好</view>
      </view>
    </view>

    <view class="flex-between home-header-main">
      <view>
        <view class="home-greeting">{{greeting}}</view>
        <view class="home-pair-status-creamy" wx:if="{{pairInfo}}">
          已配对 · 与 {{pairDisplayName}} 同行
        </view>
        <view class="home-pair-status-creamy" wx:else>
          <text bindtap="goPair">单人模式 · 点击配对 →</text>
        </view>
      </view>
      <view class="home-mood-capsule" wx:if="{{hasCheckedIn && todayCheckin}}">
        <text class="mood-emoji-sm">{{todayCheckin.mood_score == 4 ? '😊' : todayCheckin.mood_score == 3 ? '🙂' : todayCheckin.mood_score == 2 ? '😐' : '😟'}}</text>
        <text class="mood-label-sm">今日心情</text>
      </view>
    </view>

    <view class="home-hero-card">
      <view class="home-hero-card__eyebrow">TODAY</view>
      <view class="home-hero-card__title">{{hasCheckedIn ? '今天已经留下关系记录' : '先完成今天最重要的一步'}}</view>
      <view class="home-hero-card__copy">{{hasCheckedIn ? '你已经把情绪、互动和节奏留了下来，接下来更适合看简报与建议。' : '先用一次打卡，把今天的关系和心情安放下来，再决定下一步。'}}</view>
    </view>
  </view>

  <!-- 危机预警横幅 -->
  <view class="crisis-banner card" wx:if="{{hasCrisis}}" bindtap="goCrisis">
    <view class="flex-row gap-sm">
      <text class="crisis-icon">⚠️</text>
      <view class="flex-1">
        <view class="text-subtitle" style="color: var(--color-danger);">关系预警提醒</view>
        <view class="text-caption">{{crisisStatus.message || '检测到关系波动，请及时关注'}}</view>
      </view>
      <text class="text-caption">查看 ></text>
    </view>
  </view>

  <!-- 打卡天数展示 (浮动大卡片) -->
  <view class="card-creamy streak-card-creamy">
    <view class="flex-center flex-col">
      <view class="streak-number-creamy">{{streak}}</view>
      <view class="streak-label-creamy">连续打卡天数</view>
    </view>
  </view>

  <!-- 快捷操作区域 -->
  <view class="section-title-creamy mb-md mt-lg">快捷操作</view>
  <view class="flex-row gap-md">
    <!-- 今日打卡 -->
    <view class="card-creamy action-card-creamy flex-1" bindtap="goCheckin">
      <view class="action-icon-creamy">✏️</view>
      <view class="action-text-creamy">今日打卡</view>
      <view class="action-status-creamy {{hasCheckedIn ? 'done' : 'pending'}}">
        {{hasCheckedIn ? '已完成 ✓' : '待完成'}}
      </view>
    </view>

    <!-- 查看报告 -->
    <view class="card-creamy action-card-creamy flex-1" bindtap="goReport">
      <view class="action-icon-creamy">📊</view>
      <view class="action-text-creamy">查看报告</view>
      <view class="action-sub-creamy">AI 深度分析</view>
    </view>

    <!-- 关系树 -->
    <view class="card-creamy action-card-creamy flex-1" bindtap="goTree">
      <view class="action-icon-creamy">🌳</view>
      <view class="action-text-creamy">关系树</view>
      <view class="action-sub-creamy">{{treeStatus ? treeStatus.level_name : '正在生长'}}</view>
    </view>
  </view>

  <!-- 今日打卡摘要 -->
    <view class="card mt-lg" wx:if="{{hasCheckedIn && todayCheckin}}">
    <view class="text-subtitle mb-sm">今日打卡摘要</view>
    <view class="divider"></view>
    <view class="flex-between mt-sm">
      <text class="text-caption">心情评分</text>
      <text class="text-body">{{todayCheckin.mood_score || 0}} / 4</text>
    </view>
    <view class="flex-between mt-sm">
      <text class="text-caption">互动次数</text>
      <text class="text-body">{{todayCheckin.interaction_freq || 0}} 次</text>
    </view>
    <view class="flex-between mt-sm">
      <text class="text-caption">深度对话</text>
      <text class="text-body">{{todayCheckin.deep_conversation ? '有' : '无'}}</text>
    </view>
  </view>

  <!-- 加载提示 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <text class="text-caption">加载中...</text>
  </view>

</view>
