/* 专家咨询页样式 */
.container {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.expert-item {
  margin-bottom: 24rpx;
}

.expert-header {
  margin-bottom: 16rpx;
}

.expert-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

.expert-basic {
  flex: 1;
  margin-left: 20rpx;
}

.expert-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
}

.expert-title {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.expert-rating {
  display: flex;
  align-items: center;
}

.rating-star {
  font-size: 24rpx;
  margin-right: 4rpx;
}

.rating-value {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-warm);
}

.expert-specialty {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
}

.expert-stats {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.expert-action {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.expert-price {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-accent);
}
