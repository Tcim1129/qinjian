/* 关系社区页样式 */
.container {
  padding: 0;
  min-height: 100vh;
  box-sizing: border-box;
}

.tab-bar {
  display: flex;
  background: var(--color-white);
  border-bottom: 1rpx solid var(--color-border);
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  position: relative;
}

.tab-item.active {
  color: var(--color-primary);
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: var(--color-primary);
  border-radius: 2rpx;
}

.tips-list, .notifications-list {
  padding: 24rpx 32rpx;
}

.tip-item, .notification-item {
  margin-bottom: 20rpx;
}

.tip-title, .notification-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.tip-content, .notification-content {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.tip-meta {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.tip-category {
  color: var(--color-primary);
}

.notification-item.unread {
  border-left: 4rpx solid var(--color-primary);
}

.notification-time {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.read-all-btn {
  text-align: right;
  margin-bottom: 16rpx;
}

.empty-state {
  padding: 80rpx;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 40vh;
}

.loading-text {
  font-size: 28rpx;
  color: var(--color-text-muted);
}
