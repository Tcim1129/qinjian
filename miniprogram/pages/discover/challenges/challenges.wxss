/* 关系挑战赛页样式 */
.container {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 32rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.header-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.task-item {
  margin-bottom: 20rpx;
}

.task-item.completed {
  opacity: 0.6;
}

.task-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
}

.task-points {
  font-size: 24rpx;
  color: var(--color-warm);
  font-weight: 600;
}

.task-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
  margin-bottom: 16rpx;
}

.completed-badge {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background: rgba(0, 184, 148, 0.1);
  color: var(--color-success);
  border-radius: 20rpx;
  font-size: 24rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 48rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-muted);
}

.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 40vh;
}

.loading-text {
  font-size: 28rpx;
  color: var(--color-text-muted);
}
