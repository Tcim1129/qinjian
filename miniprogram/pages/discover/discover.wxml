<!-- 发现页 (参考图 2 风格) -->
<view class="discover-container container-safe animate-fade-in">
  <!-- 顶部状态栏占位/自定义头部 -->
  <view class="discover-header">
    <view class="header-left">
      <text class="brand-name">亲健</text>
      <text class="brand-sub">社区</text>
    </view>
    <view class="header-right">
      <view class="icon-btn" bindtap="goCheckin">📅 <text>签到</text></view>
      <view class="icon-btn" bindtap="goProfile">🙂 <text>我的</text></view>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar-wrap">
    <view class="search-input-box">
      <text class="search-icon">🔍</text>
      <input type="text" placeholder="搜索你感兴趣的内容/工具/课程" placeholder-class="search-placeholder" />
    </view>
  </view>

  <!-- 主服务板块 (大卡片组) -->
  <view class="main-service-grid">
    <view class="service-card-large" bindtap="goFeature" data-path="/pages/discover/experts/experts">
      <view class="service-info">
        <text class="service-title">心理咨询</text>
        <view class="service-stats">
          <text class="count">3,959,124</text> 次
        </view>
        <text class="service-desc">改变，从这里开始</text>
        <view class="consult-link">即刻咨询 ></view>
      </view>
      <view class="service-img-wrap">
        <text class="service-emoji-large">🛋️</text>
      </view>
    </view>

    <view class="service-side-column">
      <view class="service-card-small top" bindtap="goFeature" data-path="/pages/discover/community/community">
        <view class="small-info">
          <text class="small-title">即时倾诉</text>
          <text class="small-desc">情绪解压愈首选</text>
        </view>
        <text class="small-emoji">📞</text>
      </view>
      <view class="service-card-small bottom" bindtap="goFeature" data-path="/pages/discover/courses/courses">
        <view class="small-info">
          <text class="small-title">心理课程</text>
          <text class="small-desc">从入门到精通</text>
        </view>
        <text class="small-emoji">🎓</text>
      </view>
    </view>
  </view>

  <!-- 横向图标导航 -->
  <view class="quick-nav-bar">
    <view class="nav-item" wx:for="{{quickNavs}}" wx:key="name" bindtap="goQuickNav" data-path="{{item.path}}">
      <view class="nav-icon-bg">{{item.icon}}</view>
      <text class="nav-name">{{item.name}}</text>
    </view>
  </view>

  <!-- 活动横幅 -->
  <view class="promo-banner card-creamy">
    <view class="promo-content">
      <view class="promo-tag">🎁 新用户见面礼</view>
      <text class="promo-title">打开3天全部可领取</text>
      <view class="promo-items">
        <view class="promo-item">
          <view class="item-icon">🎟️</view>
          <text>50元优惠</text>
        </view>
        <view class="promo-item">
          <view class="item-icon">📋</view>
          <text>健康评估</text>
        </view>
        <view class="promo-item">
          <view class="item-icon">📚</view>
          <text>读书会 VIP</text>
        </view>
      </view>
    </view>
    <view class="promo-img">📢</view>
  </view>

  <!-- 福利榜 -->
  <view class="benefit-section">
    <view class="section-header">
      <text class="section-title">限时福利榜</text>
      <text class="section-more">查看全部 ></text>
    </view>
    <view class="benefit-list">
      <view class="benefit-item card" wx:for="{{benefits}}" wx:key="id">
        <view class="benefit-img">{{item.img}}</view>
        <view class="benefit-info">
          <view class="benefit-title">{{item.title}}</view>
          <view class="benefit-tag">{{item.tag}}</view>
          <view class="benefit-price">¥{{item.price}}</view>
        </view>
        <view class="benefit-btn">抢购</view>
      </view>
    </view>
  </view>

</view>
