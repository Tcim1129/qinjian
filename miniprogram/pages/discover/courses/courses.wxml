<!--精品课程页-->
<view class="container">
  <view class="course-list">
    <view class="course-item card" wx:for="{{courses}}" wx:key="id" data-id="{{item.id}}" bindtap="viewCourse">
      <view class="course-cover">📚</view>
      <view class="course-info">
        <view class="course-title">{{item.title}}</view>
        <view class="course-desc">{{item.desc}}</view>
        <view class="course-meta flex-between">
          <view class="course-tags">
            <text class="tag tag-primary">{{item.level}}</text>
            <text class="tag">{{item.duration}}</text>
          </view>
          <view class="course-price {{item.price === 0 ? 'free' : ''}}">
            {{item.price === 0 ? '免费' : '¥' + item.price}}
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
