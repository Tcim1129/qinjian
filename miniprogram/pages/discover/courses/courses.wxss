/* 精品课程页样式 */
.container {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.course-item {
  display: flex;
  margin-bottom: 24rpx;
  padding: 24rpx;
}

.course-cover {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, var(--color-primary-bg), var(--color-primary));
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.course-info {
  flex: 1;
  min-width: 0;
}

.course-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.course-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
}

.course-tags {
  display: flex;
  gap: 12rpx;
}

.course-price {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-accent);
}

.course-price.free {
  color: var(--color-success);
}
