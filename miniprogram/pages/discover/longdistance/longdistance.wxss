/* 异地恋工具页样式 */
.container {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.health-card {
  text-align: center;
  padding: 48rpx 32rpx;
}

.health-label {
  font-size: 26rpx;
  opacity: 0.9;
  margin-bottom: 12rpx;
}

.health-value {
  font-size: 80rpx;
  font-weight: 700;
  line-height: 1.2;
}

.health-desc {
  font-size: 24rpx;
  opacity: 0.85;
  margin-top: 8rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
}

.activity-item {
  margin-top: 16rpx;
}

.activity-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
}

.activity-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

.activity-status {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.activity-status.completed {
  color: var(--color-success);
}

.empty-state {
  padding: 48rpx;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  max-width: 600rpx;
  background: var(--color-white);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
}

.modal-close {
  font-size: 40rpx;
  color: var(--color-text-muted);
}

.modal-body {
  padding: 32rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.form-input {
  height: 80rpx;
  padding: 0 24rpx;
  background: var(--color-bg);
  border-radius: var(--radius-md);
  font-size: 28rpx;
}

.form-textarea {
  width: 100%;
  height: 120rpx;
  padding: 20rpx 24rpx;
  background: var(--color-bg);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx 32rpx;
}

.modal-footer .btn {
  flex: 1;
}

.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.loading-text {
  font-size: 28rpx;
  color: var(--color-text-muted);
}
