/* 关系健康测试页样式 */
.container {
  padding: 48rpx 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.progress-bar {
  height: 8rpx;
  background: var(--color-border);
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-secondary), var(--color-primary));
  transition: width 0.3s ease;
}

.question-number {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-bottom: 16rpx;
}

.question-text {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text);
  line-height: 1.5;
  margin-bottom: 48rpx;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option-btn {
  width: 100%;
  height: 100rpx;
  background: var(--color-white);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  color: var(--color-text);
  text-align: center;
  line-height: 100rpx;
  transition: all 0.2s;
}

.option-btn:active {
  background: var(--color-primary-bg);
  border-color: var(--color-primary);
  color: var(--color-primary);
}

.result-section {
  text-align: center;
  padding: 80rpx 32rpx;
}

.result-icon {
  font-size: 100rpx;
  margin-bottom: 32rpx;
}

.result-title {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
}

.result-score {
  font-size: 64rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 16rpx;
}

.result-level {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 24rpx;
}

.result-desc {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
  padding: 0 24rpx;
}
