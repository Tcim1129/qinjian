<!--关系健康测试页-->
<view class="container">
  <view wx:if="{{!showResult}}" class="question-section">
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{(currentQuestion + 1) / questions.length * 100}}%"></view>
    </view>
    <view class="question-number">问题 {{currentQuestion + 1}} / {{questions.length}}</view>
    <view class="question-text">{{questions[currentQuestion].q}}</view>
    <view class="options">
      <button class="option-btn" wx:for="{{questions[currentQuestion].options}}" wx:key="index" data-idx="{{index}}" bindtap="selectOption">
        {{item}}
      </button>
    </view>
  </view>

  <view wx:else class="result-section">
    <view class="result-icon">{{score >= 16 ? '💖' : score >= 12 ? '💕' : score >= 8 ? '💔' : '⚠️'}}</view>
    <view class="result-title">关系健康评分</view>
    <view class="result-score">{{score}} / 20</view>
    <view class="result-level">
      <block wx:if="{{score >= 16}}">关系非常健康</block>
      <block wx:elif="{{score >= 12}}">关系总体良好</block>
      <block wx:elif="{{score >= 8}}">关系需要关注</block>
      <block wx:else>建议寻求帮助</block>
    </view>
    <view class="result-desc">
      <block wx:if="{{score >= 16}}">你们的沟通顺畅，相互支持，关系稳固。</block>
      <block wx:elif="{{score >= 12}}">关系基础良好，可以尝试更多深度交流。</block>
      <block wx:elif="{{score >= 8}}">建议增加高质量相处时间，改善沟通方式。</block>
      <block wx:else>建议寻求专业咨询，共同面对挑战。</block>
    </view>
    <button class="btn btn-primary btn-block mt-lg" bindtap="restart">重新测试</button>
  </view>
</view>
