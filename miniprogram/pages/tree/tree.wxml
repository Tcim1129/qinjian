<!--关系树页-->
<view class="container">
  <view wx:if="{{loading}}" class="loading-wrap">
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:else>
    <view class="tree-visual">
      <view class="tree-icon">{{treeStatus.level >= 1 && treeStatus.level <= 5 ? ['🌱', '🌿', '🌲', '🌳', '🌸'][treeStatus.level - 1] : '🌱'}}</view>
      <view class="tree-level">{{treeStatus.level_name || '种子'}}</view>
      <view class="tree-desc">{{treeStatus.level >= 1 && treeStatus.level <= 5 ? ['播下爱的种子', '爱开始萌芽', '茁壮成长中', '枝繁叶茂', '爱情盛放'][treeStatus.level - 1] : '播下爱的种子'}}</view>
    </view>

    <view class="card">
      <view class="progress-section">
        <view class="progress-header flex-between">
          <text class="progress-label">浇水进度</text>
          <text class="progress-count">{{treeStatus.water_count || 0}} 次</text>
        </view>
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{(treeStatus.water_count % 10) * 10}}%;"></view>
        </view>
        <view class="progress-hint">
          距离下一级还需 <text class="highlight">{{10 - (treeStatus.water_count % 10)}}</text> 次浇水
        </view>
      </view>
    </view>

    <view class="card mt-md">
      <view class="stats-row flex-between">
        <view class="stat-item">
          <view class="stat-value">{{treeStatus.total_water || 0}}</view>
          <view class="stat-label">累计浇水</view>
        </view>
        <view class="stat-item">
          <view class="stat-value">{{treeStatus.level || 1}}</view>
          <view class="stat-label">当前等级</view>
        </view>
      </view>
    </view>

    <view class="water-section mt-lg">
      <button class="btn btn-primary btn-block water-btn" bindtap="waterTree" disabled="{{watering}}">
        <text class="water-icon">💧</text>
        {{watering ? '浇水中...' : '浇水'}}
      </button>
      <view class="water-tip">每日打卡可自动浇水一次</view>
    </view>

    <view class="level-list card mt-lg">
      <view class="level-title">成长阶段</view>
      <view class="level-items">
        <view class="level-item {{treeStatus.level >= 1 ? 'active' : ''}}">
          <text class="level-icon">🌱</text>
          <text class="level-name">种子</text>
        </view>
        <view class="level-item {{treeStatus.level >= 2 ? 'active' : ''}}">
          <text class="level-icon">🌿</text>
          <text class="level-name">嫩芽</text>
        </view>
        <view class="level-item {{treeStatus.level >= 3 ? 'active' : ''}}">
          <text class="level-icon">🌲</text>
          <text class="level-name">树苗</text>
        </view>
        <view class="level-item {{treeStatus.level >= 4 ? 'active' : ''}}">
          <text class="level-icon">🌳</text>
          <text class="level-name">小树</text>
        </view>
        <view class="level-item {{treeStatus.level >= 5 ? 'active' : ''}}">
          <text class="level-icon">🌸</text>
          <text class="level-name">花开</text>
        </view>
      </view>
    </view>
  </block>
</view>
