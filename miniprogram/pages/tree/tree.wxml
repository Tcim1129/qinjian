<!--关系树页-->
<view class="container">
  <view wx:if="{{loading}}" class="loading-wrap">
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:else>
    <view class="tree-visual">
      <view class="tree-icon">{{treeStatus.level >= 1 && treeStatus.level <= 5 ? ['🌱', '🌿', '🌲', '🌳', '🌸'][treeStatus.level - 1] : '🌱'}}</view>
      <view class="tree-level">{{treeStatus.level_name || '种子'}}</view>
      <view class="tree-desc">{{treeStatus.level >= 1 && treeStatus.level <= 5 ? ['播下爱的种子', '爱开始萌芽', '茁壮成长中', '枝繁叶茂', '爱情盛放'][treeStatus.level - 1] : '播下爱的种子'}}</view>
    </view>

    <view class="card-creamy water-progress-card-creamy animate-slide-up">
      <view class="progress-section-creamy">
        <view class="progress-header-creamy flex-between">
          <text class="progress-label-creamy">浇水进度</text>
          <view class="progress-count-badge-creamy">{{treeStatus.water_count || 0}} 次</view>
        </view>
        <view class="progress-bar-creamy">
          <view class="progress-fill-creamy" style="width: {{(treeStatus.water_count % 10) * 10}}%;"></view>
        </view>
        <view class="progress-hint-creamy">
          距离下一级还需 <text class="highlight-creamy">{{10 - (treeStatus.water_count % 10)}}</text> 次浇水
        </view>
      </view>
    </view>

    <view class="card-creamy mt-md">
      <view class="stats-row-creamy flex-between">
        <view class="stat-item-creamy">
          <view class="stat-value-creamy">{{treeStatus.total_water || 0}}</view>
          <view class="stat-label-creamy">累计浇水</view>
        </view>
        <view class="stat-item-creamy">
          <view class="stat-value-creamy">{{treeStatus.level || 1}}</view>
          <view class="stat-label-creamy">当前等级</view>
        </view>
      </view>
    </view>

    <view class="water-section mt-lg">
      <button class="btn btn-primary btn-block water-btn" bindtap="waterTree" disabled="{{watering}}">
        <text class="water-icon">💧</text>
        {{watering ? '浇水中...' : '浇水'}}
      </button>
      <view class="water-tip">每日打卡可自动浇水一次</view>
    </view>

    <view class="card-creamy mt-lg level-list-creamy">
      <view class="section-title-creamy mb-md">成长轨迹</view>
      <view class="level-items-creamy">
        <view class="level-node-creamy {{treeStatus.level >= 1 ? 'active' : ''}}">
          <view class="level-node-icon-creamy">🌱</view>
          <text class="level-node-name-creamy">种子</text>
        </view>
        <view class="level-node-creamy {{treeStatus.level >= 2 ? 'active' : ''}}">
          <view class="level-node-icon-creamy">🌿</view>
          <text class="level-node-name-creamy">嫩芽</text>
        </view>
        <view class="level-node-creamy {{treeStatus.level >= 3 ? 'active' : ''}}">
          <view class="level-node-icon-creamy">🌲</view>
          <text class="level-node-name-creamy">树苗</text>
        </view>
        <view class="level-node-creamy {{treeStatus.level >= 4 ? 'active' : ''}}">
          <view class="level-node-icon-creamy">🌳</view>
          <text class="level-node-name-creamy">小树</text>
        </view>
        <view class="level-node-creamy {{treeStatus.level >= 5 ? 'active' : ''}}">
          <view class="level-node-icon-creamy">🌸</view>
          <text class="level-node-name-creamy">成熟</text>
        </view>
      </view>
    </view>
  </block>
</view>
