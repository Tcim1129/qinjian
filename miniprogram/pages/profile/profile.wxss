/* 个人中心特有样式 */

/* 奶油风格用户信息头部 */
.profile-header-creamy {
  padding: 60rpx 40rpx;
  background: linear-gradient(135deg, rgba(255, 244, 236, 0.96), rgba(240, 250, 252, 0.88));
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 26rpx;
}

.profile-brand-ribbon {
  align-self: flex-start;
}

.profile-avatar-creamy {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  overflow: hidden;
  background: #f0f0f0;
  border: 4rpx solid rgba(108, 92, 231, 0.1);
}

.profile-avatar-img-creamy {
  width: 100%;
  height: 100%;
}

.profile-avatar-placeholder-creamy {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  background: linear-gradient(135deg, #a29bfe, #6c5ce7);
  color: #ffffff;
}

.profile-nickname-creamy {
  font-size: 40rpx;
  font-weight: 800;
  color: #2d2a32;
}

.pair-status-tag-creamy {
  font-size: 20rpx;
  background: #fff9f0;
  color: #5d4037;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 700;
  border: 1rpx solid #f5efeb;
}

.pair-status-tag-creamy.paired {
  background: #e8f5e9;
  color: #2e7d32;
}

.pair-status-tag-creamy.not-paired {
  background: #fff3e0;
  color: #ef6c00;
}

.arrow-icon-creamy {
  font-size: 32rpx;
  color: #ccc;
}

/* 奶油风格菜单列表 */
.menu-list-creamy {
  padding: 10rpx 0;
}

.menu-item-creamy {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 40rpx;
  transition: all 0.2s;
}

.menu-item-creamy:active {
  background: #fff9f0;
}

.divider-creamy {
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-icon-box-creamy {
  font-size: 40rpx;
  width: 50rpx;
  text-align: center;
}

.menu-title-creamy {
  font-size: 28rpx;
  font-weight: 600;
  color: #444;
}

.arrow-sm-creamy {
  color: #bbb;
  font-size: 32rpx;
}

.text-danger {
  color: var(--color-danger);
}

.profile-copyright-card {
  text-align: center;
  padding: 32rpx 28rpx;
}

.profile-copyright-eyebrow {
  font-size: 20rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  color: #a1887f;
}

.profile-copyright-text {
  margin-top: 14rpx;
  font-size: 22rpx;
  line-height: 1.8;
  color: #6d4c41;
}
