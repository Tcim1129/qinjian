<!--
  个人中心页 - 头像信息 + 菜单列表
-->
<view class="container container-safe">

  <!-- 用户信息头部 -->
  <!-- 用户信息头部 (奶油风格大卡片) -->
  <view class="card-creamy profile-header-creamy animate-fade-in" bindtap="onMenuTap" data-id="pair" data-path="/pages/pair/pair">
    <view class="brand-ribbon profile-brand-ribbon">
      <image class="brand-ribbon__logo" src="/images/brand-logo.jpg" mode="aspectFit"></image>
      <view class="brand-ribbon__copy">
        <view class="brand-ribbon__eyebrow">QINJIAN MINI</view>
        <view class="brand-ribbon__title">我的关系空间</view>
      </view>
    </view>
    <view class="flex-row gap-lg">
      <!-- 头像 -->
      <view class="profile-avatar-creamy">
        <image
          wx:if="{{userInfo && userInfo.avatar}}"
          src="{{userInfo.avatar}}"
          class="profile-avatar-img-creamy"
          mode="aspectFill"
        ></image>
        <view wx:else class="profile-avatar-placeholder-creamy">
          <text>{{userInfo && userInfo.nickname ? userInfo.nickname[0] : '亲'}}</text>
        </view>
      </view>
 
      <!-- 名称与状态 -->
      <view class="flex-1">
        <view class="profile-nickname-creamy">{{userInfo ? userInfo.nickname : '立即登录'}}</view>
        <view class="mt-sm">
          <view class="pair-status-tag-creamy {{isPaired ? 'paired' : 'not-paired'}}">
            {{isPaired ? '已配对 · ' + (pairInfo.partner_nickname || pairInfo.partner_name || pairInfo.partnerNickname || '伴侣') : '尚未配对 · 建立连接'}}
          </view>
        </view>
      </view>
 
      <view class="arrow-icon-creamy">chevron_right</view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <!-- 功能菜单 (分组奶油卡片) -->
  <view class="card-creamy mt-md menu-list-creamy">
    <view
      wx:for="{{menuItems}}"
      wx:key="id"
      class="menu-item-creamy {{index !== menuItems.length - 1 ? 'divider-creamy' : ''}}"
      bindtap="onMenuTap"
      data-id="{{item.id}}"
      data-path="{{item.path}}"
    >
      <view class="flex-row gap-md">
        <view class="menu-icon-box-creamy">{{item.icon}}</view>
        <text class="menu-title-creamy {{item.id === 'logout' ? 'text-danger' : ''}}">{{item.title}}</text>
      </view>
      <view class="arrow-sm-creamy" wx:if="{{item.id !== 'logout'}}">›</view>
    </view>
  </view>

  <view class="card-creamy mt-md profile-copyright-card">
    <view class="profile-copyright-eyebrow">COPYRIGHT</view>
    <view class="profile-copyright-text">版权所有：心晴合伙人项目组 黄菁蓝、吴秀秀、叶笙尧、钟昊桐、郑梓滢</view>
  </view>

</view>
