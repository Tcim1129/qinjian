<view class="checkin-page container-safe">
  <view class="checkin-hero">
    <view>
      <view class="hero-eyebrow">CHECK-IN</view>
      <view class="hero-title">{{mode === 'voice' ? 'AI 语音陪伴打卡' : '四步关系打卡'}}</view>
      <view class="hero-subtitle">{{mode === 'voice' ? '像豆包那样聊一聊，系统会帮你提炼成今天的记录。' : '把今天留下一点痕迹，后面的洞察和报告都会更准。'}}</view>
    </view>
    <view class="mode-switch">
      <view class="mode-chip {{mode === 'form' ? 'active' : ''}}" bindtap="switchMode" data-mode="form">表单</view>
      <view class="mode-chip {{mode === 'voice' ? 'active' : ''}}" bindtap="switchMode" data-mode="voice">语音</view>
    </view>
  </view>

  <block wx:if="{{mode === 'form'}}">
    <block wx:if="{{hasCheckedIn && todayCheckin}}">
      <view class="card-creamy summary-card">
        <view class="summary-icon">✨</view>
        <view class="section-title-creamy mt-sm">今日打卡已完成</view>
        <view class="text-caption mt-sm">每天一次记录，让关系被看见</view>
      </view>

      <view class="card-creamy mt-md summary-panel">
        <view class="section-title-creamy mb-sm">打卡摘要</view>
        <view class="summary-row"><text>心情评分</text><text>{{todayCheckin.mood_score || '--'}}</text></view>
        <view class="summary-row"><text>互动次数</text><text>{{todayCheckin.interaction_freq || 0}} 次</text></view>
        <view class="summary-row"><text>深度对话</text><text>{{todayCheckin.deep_conversation ? '有' : '无'}}</text></view>
        <view class="summary-row"><text>任务完成</text><text>{{todayCheckin.task_completed ? '已完成' : '未完成'}}</text></view>
        <view class="summary-copy" wx:if="{{todayCheckin.content}}">{{todayCheckin.content}}</view>
      </view>
    </block>

    <block wx:else>
      <view class="card-creamy progress-card">
        <view class="step-progress-bar-creamy">
          <view class="step-progress-fill-creamy" style="width: {{currentStep / totalSteps * 100}}%"></view>
        </view>
        <view class="step-indicator-text">步骤 {{currentStep}} / {{totalSteps}}</view>
      </view>

      <view class="card-creamy mt-lg" wx:if="{{currentStep === 1}}">
        <view class="section-title-creamy text-center">今天的心情如何？</view>
        <view class="mood-grid-creamy mt-lg">
          <view
            wx:for="{{moodOptions}}"
            wx:key="score"
            class="mood-item-creamy {{moodScore === item.score ? 'active' : ''}}"
            bindtap="selectMood"
            data-score="{{item.score}}"
          >
            <view class="mood-emoji-box">{{item.emoji}}</view>
            <text class="mood-label-creamy">{{item.label}}</text>
          </view>
        </view>
      </view>

      <view class="card-creamy mt-lg" wx:if="{{currentStep === 2}}">
        <view class="section-title-creamy text-center">今天有几次有效互动？</view>
        <view class="counter-wrap mt-lg">
          <button class="counter-btn" bindtap="onInteractionInput" data-delta="-1">-</button>
          <input class="counter-input" type="number" value="{{interactionCount}}" bindinput="onInteractionInput" />
          <button class="counter-btn" bindtap="onInteractionInput" data-delta="1">+</button>
        </view>
        <view class="text-caption text-center mt-md">谁更主动一点？</view>
        <view class="choice-grid mt-md">
          <view class="choice-chip {{initiativeScore === 'me' ? 'active' : ''}}" bindtap="selectInitiative" data-value="me">我更主动</view>
          <view class="choice-chip {{initiativeScore === 'equal' ? 'active' : ''}}" bindtap="selectInitiative" data-value="equal">差不多</view>
          <view class="choice-chip {{initiativeScore === 'partner' ? 'active' : ''}}" bindtap="selectInitiative" data-value="partner">对方更主动</view>
        </view>
      </view>

      <view class="card-creamy mt-lg" wx:if="{{currentStep === 3}}">
        <view class="section-title-creamy text-center">今天有深度交流吗？</view>
        <view class="toggle-group-creamy mt-xl">
          <view class="toggle-card-creamy {{deepConversation === true ? 'active' : ''}}" bindtap="toggleDeepConversation" data-val="true">
            <text class="toggle-emoji-creamy">💬</text>
            <text class="toggle-text-creamy">有深聊</text>
          </view>
          <view class="toggle-card-creamy {{deepConversation === false ? 'active' : ''}}" bindtap="toggleDeepConversation" data-val="false">
            <text class="toggle-emoji-creamy">🌙</text>
            <text class="toggle-text-creamy">没有</text>
          </view>
        </view>
      </view>

      <view class="card-creamy mt-lg" wx:if="{{currentStep === 4}}">
        <view class="section-title-creamy text-center">补一句今天最想留下的话</view>
        <textarea class="free-text-area mt-md" placeholder="比如：今天终于把心里的委屈说开了。" value="{{freeText}}" bindinput="onFreeTextInput" maxlength="500"></textarea>
        <view class="task-row mt-md" bindtap="toggleTaskCompleted">
          <text class="task-label">今日小任务：给对方一个具体赞美</text>
          <text class="task-state">{{taskCompleted ? '已完成' : '待完成'}}</text>
        </view>

        <view class="text-caption mt-md">情绪标签</view>
        <view class="flex-row flex-wrap gap-sm mt-sm">
          <view wx:for="{{emotionTags}}" wx:key="*this" class="tag {{selectedTags.indexOf(item) >= 0 ? 'tag-primary' : ''}} emotion-tag" bindtap="toggleTag" data-tag="{{item}}">{{item}}</view>
        </view>

        <view class="mt-md">
          <view class="text-caption">图片附件（可选）</view>
          <view class="flex-row flex-wrap gap-sm mt-sm">
            <view wx:for="{{imageList}}" wx:key="*this" class="image-preview-wrap">
              <image src="{{item}}" class="image-preview" mode="aspectFill"></image>
              <view class="image-remove" bindtap="removeImage" data-idx="{{index}}">✕</view>
            </view>
            <view class="image-add" bindtap="chooseImage" wx:if="{{imageList.length < 3}}"><text>+</text></view>
          </view>
        </view>

        <view class="mt-md">
          <view class="text-caption">语音附件（可选）</view>
          <view class="flex-row gap-sm mt-sm" wx:if="{{!voicePath}}">
            <button class="btn btn-secondary btn-small" bindtap="chooseVoice">{{isRecording ? '结束录音' : '录制语音'}}</button>
          </view>
          <view class="flex-row gap-sm mt-sm" wx:else>
            <view class="tag tag-primary">已录制语音</view>
            <text class="text-caption text-danger" bindtap="clearVoice">删除</text>
          </view>
        </view>
      </view>

      <view class="checkin-actions-floating">
        <button class="btn btn-outline flex-1" bindtap="prevStep" wx:if="{{currentStep > 1}}">上一步</button>
        <button class="btn btn-primary flex-1" bindtap="nextStep" wx:if="{{currentStep < totalSteps}}">下一步</button>
        <button class="btn btn-primary flex-1 {{submitting ? 'btn-disabled' : ''}}" bindtap="submitCheckin" wx:if="{{currentStep === totalSteps}}" disabled="{{submitting}}">{{submitting ? '提交中...' : '提交打卡'}}</button>
      </view>
    </block>
  </block>

  <block wx:else>
    <view class="card-creamy voice-card">
      <view class="section-title-creamy">AI 语音陪伴</view>
      <view class="text-caption mt-sm">你可以直接输入，也可以先录音。AI 会边聊边整理今天的关系记录。</view>
      <view class="voice-action-row mt-lg">
        <button class="btn btn-primary flex-1" bindtap="toggleVoiceChatRecord">{{isRecording ? '结束录音' : '开始录音'}}</button>
        <button class="btn btn-secondary flex-1" bindtap="startVoiceRecognize">{{recognizingVoice ? '识别中' : '语音识别'}}</button>
        <button class="btn btn-outline flex-1" bindtap="playLastReply">播放回复</button>
      </view>
    </view>

    <view class="card-creamy mt-md chat-card">
      <view class="chat-list" wx:if="{{chatMessages.length}}">
        <view wx:for="{{chatMessages}}" wx:key="id" class="chat-item {{item.role === 'user' ? 'chat-item-user' : 'chat-item-ai'}}">
          <view class="chat-role">{{item.role === 'user' ? '我' : '亲健AI'}}</view>
          <view class="chat-bubble">{{item.content}}</view>
        </view>
      </view>
      <view class="empty-state" wx:else>从一句“今天其实有点累”开始也可以。</view>
      <textarea class="chat-input mt-md" placeholder="输入一句话，或者先录音再发送" value="{{chatInput}}" bindinput="onChatInput" maxlength="200"></textarea>
      <button class="btn btn-primary btn-block mt-md" bindtap="sendChat">发送给 AI</button>
    </view>
  </block>
</view>
