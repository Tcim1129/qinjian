/* 打卡页特有样式 */

.checkin-done-emoji {
  font-size: 80rpx;
}

/* 进度条 */
.step-progress {
  margin-top: var(--spacing-md);
}

.step-progress-bar {
  height: 8rpx;
  background: var(--color-border);
  border-radius: var(--radius-round);
  overflow: hidden;
}

.step-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-primary), var(--color-primary-light));
  border-radius: var(--radius-round);
  transition: width 0.3s ease;
}

/* 心情选择网格 */
.mood-grid {
  display: flex;
  justify-content: space-around;
  gap: var(--spacing-md);
}

.mood-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-lg) var(--spacing-md);
  border-radius: var(--radius-lg);
  background: var(--color-bg);
  border: 2rpx solid transparent;
  transition: all 0.2s;
  min-width: 120rpx;
}

.mood-item-active {
  border-color: var(--color-primary);
  background: var(--color-primary-bg);
  transform: scale(1.05);
}

.mood-item-emoji {
  font-size: 56rpx;
  margin-bottom: var(--spacing-xs);
}

.mood-item-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* 切换按钮组 */
.toggle-group {
  display: flex;
  gap: var(--spacing-lg);
  justify-content: center;
}

.toggle-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl) var(--spacing-lg);
  border-radius: var(--radius-lg);
  background: var(--color-bg);
  border: 2rpx solid transparent;
  min-width: 200rpx;
  transition: all 0.2s;
}

.toggle-btn-active {
  border-color: var(--color-primary);
  background: var(--color-primary-bg);
}

.toggle-emoji {
  font-size: 48rpx;
  margin-bottom: var(--spacing-sm);
}

/* 自由文本域 */
.free-text-area {
  width: 100%;
  height: 180rpx;
  background: var(--color-bg);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  font-size: 28rpx;
  color: var(--color-text);
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

.free-text-area:focus {
  border-color: var(--color-primary);
  background: var(--color-white);
}

/* 情绪标签 */
.emotion-tag {
  border: 2rpx solid var(--color-border);
  background: var(--color-white);
}

/* 图片上传 */
.image-preview-wrap {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.image-preview {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-md);
}

.image-remove {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 36rpx;
  height: 36rpx;
  background: var(--color-danger);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

.image-add {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed var(--color-border);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: var(--color-text-muted);
}

/* 底部操作栏 */
.checkin-actions {
  padding-bottom: var(--spacing-lg);
}
