.checkin-page {
  min-height: 100vh;
  padding: 28rpx 28rpx 240rpx;
  box-sizing: border-box;
}

.checkin-hero {
  padding: 24rpx 0 12rpx;
}

.hero-eyebrow {
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: var(--color-cream-sub);
}

.hero-title {
  font-size: 46rpx;
  line-height: 1.2;
  font-weight: 800;
  color: var(--color-cream-text);
  margin-top: 16rpx;
}

.hero-subtitle {
  font-size: 24rpx;
  line-height: 1.8;
  color: var(--color-text-secondary);
  margin-top: 14rpx;
}

.mode-switch {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.mode-chip {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(93, 64, 55, 0.08);
  color: var(--color-text-secondary);
  font-size: 22rpx;
  font-weight: 700;
}

.mode-chip.active {
  background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
  color: #fff;
}

.summary-card,
.summary-panel,
.progress-card,
.voice-card,
.chat-card {
  margin-top: 18rpx;
}

.summary-icon {
  font-size: 72rpx;
  text-align: center;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--color-cream-border);
}

.summary-row:last-of-type {
  border-bottom: none;
}

.summary-copy {
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: var(--color-text-secondary);
}

.step-progress-bar-creamy {
  height: 12rpx;
  background: #f0e3d7;
  border-radius: 999rpx;
  overflow: hidden;
}

.step-progress-fill-creamy {
  height: 100%;
  background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
  border-radius: 999rpx;
}

.step-indicator-text {
  text-align: center;
  font-size: 22rpx;
  color: var(--color-cream-sub);
  margin-top: 12rpx;
}

.mood-grid-creamy {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.mood-item-creamy {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 28rpx 10rpx;
  border-radius: 28rpx;
  background: #fbf4ec;
  border: 3rpx solid transparent;
}

.mood-item-creamy.active {
  border-color: var(--color-primary);
  background: #fff;
}

.mood-emoji-box {
  font-size: 60rpx;
}

.mood-label-creamy {
  font-size: 24rpx;
  font-weight: 700;
}

.counter-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.counter-btn {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  border: none;
  background: rgba(93, 64, 55, 0.1);
  color: var(--color-primary);
  font-size: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.counter-input {
  width: 180rpx;
  height: 88rpx;
  border-radius: 22rpx;
  background: #fbf4ec;
  text-align: center;
  font-size: 36rpx;
  font-weight: 800;
  color: var(--color-primary);
}

.choice-grid {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
  justify-content: center;
}

.choice-chip {
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: #fbf4ec;
  color: var(--color-text-secondary);
  font-size: 22rpx;
  font-weight: 700;
}

.choice-chip.active {
  background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
  color: #fff;
}

.toggle-group-creamy {
  display: flex;
  gap: 18rpx;
}

.toggle-card-creamy {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  padding: 34rpx 20rpx;
  background: #fbf4ec;
  border-radius: 28rpx;
  border: 3rpx solid transparent;
}

.toggle-card-creamy.active {
  border-color: var(--color-primary);
  background: #fff;
}

.toggle-emoji-creamy {
  font-size: 54rpx;
}

.toggle-text-creamy {
  font-size: 24rpx;
  font-weight: 700;
}

.free-text-area,
.chat-input {
  width: 100%;
  min-height: 180rpx;
  border-radius: 24rpx;
  background: #fbf4ec;
  padding: 24rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  color: var(--color-text);
}

.task-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  background: #fff8f1;
}

.task-label,
.task-state {
  font-size: 22rpx;
}

.task-state {
  color: var(--color-primary);
  font-weight: 700;
}

.emotion-tag {
  border: 2rpx solid var(--color-border);
  background: var(--color-white);
}

.image-preview-wrap {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.image-preview {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
}

.image-remove {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  background: var(--color-danger);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

.image-add {
  width: 160rpx;
  height: 160rpx;
  border-radius: 24rpx;
  border: 2rpx dashed var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  color: var(--color-cream-sub);
}

.checkin-actions-floating {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: calc(126rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 16rpx;
  z-index: 30;
}

.voice-action-row {
  display: flex;
  gap: 16rpx;
}

.chat-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.chat-item {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.chat-item-user {
  align-items: flex-end;
}

.chat-item-ai {
  align-items: flex-start;
}

.chat-role {
  font-size: 20rpx;
  color: var(--color-cream-sub);
}

.chat-bubble {
  max-width: 88%;
  padding: 18rpx 22rpx;
  border-radius: 24rpx;
  background: #fbf4ec;
  color: var(--color-text);
  font-size: 24rpx;
  line-height: 1.8;
}

.chat-item-user .chat-bubble {
  background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
  color: #fff;
}
