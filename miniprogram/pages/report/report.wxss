/* 报告页特有样式 */

/* 奶油风格 Tab 选择器 */
.report-tabs-creamy {
  background: #f0f0f0;
  border-radius: 40rpx;
  padding: 8rpx;
  margin-bottom: 32rpx;
}

.report-tab-creamy {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  padding: 16rpx 0;
  border-radius: 32rpx;
  color: #888;
  transition: all 0.2s;
}

.report-tab-creamy.active {
  background: #ffffff;
  color: #5d4037;
  font-weight: 800;
  box-shadow: 0 4rpx 12rpx rgba(93, 64, 55, 0.08);
}

/* 奶油风格报告内容 */
.report-content-creamy {
  padding: 48rpx 32rpx;
}

.report-header-creamy {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 40rpx;
}

.report-date-creamy {
  font-size: 20rpx;
  color: #999;
}

.report-health-creamy {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.health-ring-creamy {
  width: 140rpx;
  height: 140rpx;
  border: 12rpx solid #5d4037;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  margin-bottom: 16rpx;
}

.health-score-creamy {
  font-size: 48rpx;
  font-weight: 900;
  color: #5d4037;
}

.health-unit-creamy {
  font-size: 22rpx;
  color: #5d4037;
  margin-top: 10rpx;
}

.health-desc-creamy {
  font-size: 24rpx;
  color: #888;
}

/* AI 洞察大卡片 */
.insight-card-creamy {
  background: #fff9f0;
  border-radius: 24rpx;
  padding: 32rpx;
  border-left: 8rpx solid #8d6e63;
}

.insight-tag-creamy {
  font-size: 20rpx;
  color: #5d4037;
  font-weight: 800;
  margin-bottom: 12rpx;
}

.insight-text-creamy {
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
}

.sub-title-creamy {
  font-size: 30rpx;
  font-weight: 800;
  color: #2d2a32;
}

.report-list-item-creamy {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  border: 1rpx solid #f0f0f0;
  margin-bottom: 12rpx;
}

.report-list-item-creamy.concern {
  border-left: 6rpx solid #ff8e9b;
}

.suggestion-box-creamy {
  background: #fff9e6;
  border-radius: 24rpx;
  padding: 32rpx;
}

.suggestion-text-creamy {
  font-size: 26rpx;
  color: #e67e22;
  line-height: 1.6;
}

/* 评分条 */
.report-score-bar {
  flex: 1;
  height: 12rpx;
  background: var(--color-border);
  border-radius: var(--radius-round);
  margin: 0 var(--spacing-md);
  overflow: hidden;
}

.report-score-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-primary), var(--color-secondary));
  border-radius: var(--radius-round);
}

/* 建议 */
.report-suggestion {
  margin-top: var(--spacing-xs);
  padding-left: var(--spacing-sm);
}

/* 趋势卡片 (奶油风格) */
.trend-card-creamy {
  padding: 40rpx 32rpx;
}

.trend-mock-placeholder {
  height: 240rpx;
  background: #f8f9fd;
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.trend-mock-icon {
  font-size: 80rpx;
}

.trend-mock-data {
  display: flex;
  gap: 32rpx;
  font-size: 24rpx;
  color: #999;
  font-weight: 600;
}

/* 历史列表 */
.history-item {
  transition: transform 0.15s;
}

.history-item:active {
  transform: scale(0.98);
}
