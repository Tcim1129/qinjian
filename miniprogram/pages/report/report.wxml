<!--
  报告页 - 日报/周报/月报 切换 + 生成 + 历史 + 趋势
-->
<view class="container container-safe">

  <!-- Tab 选择器 -->
  <!-- Tab 选择器 (奶油风格) -->
  <view class="report-tabs-creamy flex-row">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="report-tab-creamy {{currentTab === item.key ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="{{item.key}}"
    >
      {{item.label}}
    </view>
  </view>

  <!-- 生成报告按钮 -->
  <view class="mt-lg">
    <button
      class="btn btn-primary btn-block {{generating ? 'btn-disabled' : ''}}"
      bindtap="generateReport"
      disabled="{{generating}}"
    >
      {{generating ? '正在生成...' : '生成' + (currentTab === 'daily' ? '日报' : currentTab === 'weekly' ? '周报' : '月报')}}
    </button>
  </view>

  <!-- 报告内容展示区 -->
  <!-- 报告内容展示区 (奶油风大卡片) -->
  <view class="card-creamy mt-lg report-content-creamy animate-fade-in" wx:if="{{reportView}}">
    <view class="report-header-creamy">
      <view class="section-title-creamy">{{reportView.title || '报告详情'}}</view>
      <view class="report-date-creamy">{{reportView.created_at}}</view>
    </view>

    <view class="report-health-creamy" wx:if="{{reportView.healthScore !== null && reportView.healthScore !== undefined}}">
      <view class="health-ring-creamy">
        <view class="health-score-creamy">{{reportView.healthScore}}</view>
        <view class="health-unit-creamy">分</view>
      </view>
      <view class="health-desc-creamy">综合关系健康评价</view>
    </view>

    <view class="insight-card-creamy mt-md" wx:if="{{reportView.insight}}">
      <view class="insight-tag-creamy">AI 核心洞察</view>
      <view class="insight-text-creamy">{{reportView.insight}}</view>
    </view>

    <view class="mt-lg" wx:if="{{reportView.highlights.length}}">
      <view class="sub-title-creamy mb-sm">✨ 关系亮点</view>
      <view class="report-list-item-creamy" wx:for="{{reportView.highlights}}" wx:key="*this">
        {{item}}
      </view>
    </view>

    <view class="mt-lg" wx:if="{{reportView.concerns.length}}">
      <view class="sub-title-creamy mb-sm">⚠️ 需要关注</view>
      <view class="report-list-item-creamy concern" wx:for="{{reportView.concerns}}" wx:key="*this">
        {{item}}
      </view>
    </view>

    <view class="suggestion-box-creamy mt-lg" wx:if="{{reportView.suggestion}}">
      <view class="sub-title-creamy mb-sm">💡 专属建议</view>
      <view class="suggestion-text-creamy">{{reportView.suggestion}}</view>
    </view>
  </view>

  <!-- 趋势图表占位区 -->
  <!-- 趋势图表区 (奶油风背景) -->
  <view class="card-creamy mt-lg trend-card-creamy" wx:if="{{trendData}}">
    <view class="section-title-creamy mb-md">情感趋势</view>
    <view class="trend-canvas-creamy">
      <view class="trend-mock-placeholder">
        <text class="trend-mock-icon">📈</text>
        <view class="trend-mock-data">
          <text>心情：{{trendData.avg_mood || '--'}}</text>
          <text>互动：{{trendData.avg_interaction || '--'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 历史报告列表 -->
  <view class="mt-lg">
    <view class="text-subtitle mb-md">历史报告</view>

    <view class="loading-wrap" wx:if="{{loading}}">
      <text class="text-caption">加载中...</text>
    </view>

    <view wx:if="{{!loading && historyList.length === 0}}" class="empty-state">
      <view class="empty-state-text">暂无历史报告</view>
    </view>

    <view
      wx:for="{{historyListView}}"
      wx:key="id"
      class="card history-item"
      bindtap="viewReport"
      data-report="{{item}}"
    >
      <view class="flex-between">
        <view>
          <view class="text-body">{{item._label || '报告'}}</view>
          <view class="text-small mt-sm">{{item.created_at || ''}}</view>
        </view>
        <text class="text-caption">查看 ></text>
      </view>
    </view>
  </view>

</view>
