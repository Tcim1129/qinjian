.floating-tab-shell {
  position: fixed;
  left: 50%;
  right: auto;
  bottom: calc(18rpx + env(safe-area-inset-bottom));
  transform: translateX(-50%);
  width: calc(100vw - 48rpx);
  max-width: 760rpx;
  z-index: 999;
  pointer-events: none;
}

.floating-tab-bar {
  pointer-events: auto;
  width: 100%;
  margin: 0;
  padding: 16rpx 18rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  background: rgba(255, 253, 249, 0.94);
  backdrop-filter: blur(16rpx);
  box-shadow: 0 18rpx 40rpx rgba(93, 64, 55, 0.14);
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 1rpx solid rgba(212, 163, 115, 0.16);
}

.tab-item {
  flex: 1;
  width: auto;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 10rpx 0;
  color: #bcaaa4;
}

.tab-item.active {
  color: #5d4037;
}

.tab-text {
  font-size: 20rpx;
  font-weight: 700;
}

.tab-icon {
  width: 42rpx;
  height: 42rpx;
  display: block;
}
