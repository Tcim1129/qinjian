.env
.env.local
.env.*.local
.env.production
.env.development
*.env

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
venv/
ENV/
env/
.venv

# === 日志和临时文件 ===
*.log
*.tmp
*.temp
*.bak
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# === IDE 和编辑器 ===
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
*.code-workspace

